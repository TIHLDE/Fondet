# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage
/test-results/
/playwright-report/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.playwright-mcp/
CLAUDE.md
.claude/
.mcp.json

# editors
.idea
.vscode

# stray shell/env dotfiles that leak into the workdir from the sandbox mount
.bashrc
.zshrc
.bash_profile
.zprofile
.profile
.gitconfig
.gitmodules
.ripgreprc

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts


# local volume dir (prod uses DATA_DIR mount; never commit runtime data)
/data
